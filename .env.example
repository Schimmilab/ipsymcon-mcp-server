# IP-Symcon JSON-RPC endpoint (default port 3777). Required.
# The "/api/" suffix is added automatically if you omit it.
IPS_URL=http://192.168.1.10:3777/api/

# HTTP Basic Auth credentials of an IP-Symcon user that has JSON-RPC access.
# Leave empty if your installation has no authentication.
IPS_USER=
IPS_PASSWORD=

# Safety gate. Default off = only read tools work.
# Set to true to allow write/dev tools (SetValue, RequestAction, RunScript,
# SetScriptContent, CreateScript, ips_call). Recommended: enable only against a
# test/staging instance and keep a backup.
IPS_ENABLE_WRITE=false
